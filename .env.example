# DocuSeal on Railway — Environment Variables for Ally Renewal
# Copy these to your Railway service Variables tab.
# Do NOT commit actual values to git.

# -- Core -------------------------------------------
# Railway injects DATABASE_URL automatically from the Postgres plugin reference
# DATABASE_URL=${{Postgres.DATABASE_URL}}
RAILS_ENV=production
PORT=3000
FORCE_SSL=true
APP_URL=https://sign.allyrenewal.com

# Generate with: openssl rand -hex 64
SECRET_KEY_BASE=

# -- Supabase S3-Compatible Storage ----------------
# Bucket: create "docuseal-contracts" (private) in Supabase Storage
S3_ATTACHMENTS_BUCKET=docuseal-contracts

# Your Supabase project ref (e.g., abcdefgh)
AWS_ACCESS_KEY_ID=

# Your Supabase service_role secret key
AWS_SECRET_ACCESS_KEY=

# Your Supabase project region (e.g., us-east-1)
AWS_REGION=

# https://<project-ref>.supabase.co/storage/v1/s3
S3_ENDPOINT=

# -- Email (so DocuSeal can send signing links) -----
SMTP_ADDRESS=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_DOMAIN=allyrenewal.com

# -- Security ----------------------------------------
# Generate with: openssl rand -hex 24
# Protects the Sidekiq dashboard at /jobs
SIDEKIQ_BASIC_AUTH_PASSWORD=
